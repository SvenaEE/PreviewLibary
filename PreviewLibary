local navbarCollapsed = true
local currentNavbarWidth = 50
local currentIndicatorY = 87
local targetIndicatorY = 87
local tabs = {}
local activeTabId = nil

local function switchTab(id)
    if activeTabId == id then return end
    for tabId, tabData in pairs(tabs) do
        if tabId == id then
            tabData.Icon.ImageColor3 = THEME.Text
            tabData.Text.TextColor3 = THEME.Text
            tabData.Container.Visible = true
            tabData.Container.GroupTransparency = 1
            TweenService:Create(tabData.Container, TweenInfo.new(0.22, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {GroupTransparency = 0}):Play()
            targetIndicatorY = tabData.Button.Position.Y.Offset
            TabIndicator.Visible = true
        else
            tabData.Icon.ImageColor3 = THEME.TextDisabled
            tabData.Text.TextColor3 = THEME.TextDisabled
            if tabData.Container.Visible then
                local c = tabData.Container
                TweenService:Create(c, TweenInfo.new(0.22, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {GroupTransparency = 1}):Play()
                task.delay(0.24, function()
                    if c and c.Parent and tabs[activeTabId] and tabs[activeTabId].Container ~= c then
                        c.Visible = false
                    end
                end)
            end
        end
    end
    activeTabId = id
end

