            colorDot.BorderSizePixel = 0
            colorDot.ZIndex = 252
            colorDot.Parent = bottomRow
            Instance.new("UICorner", colorDot).CornerRadius = UDim.new(0, 2)

            local function refreshColor()
                local c = hsvToRgb(h, s, v)
                preview.BackgroundColor3 = c
                preview.BackgroundTransparency = 1 - a
                colorDot.BackgroundColor3 = c
                colorDot.BackgroundTransparency = 1 - a
                svBg.ImageColor3 = hsvToRgb(h, 1, 1)
                hexLabel.Text = string.format("#%02X%02X%02X", math.floor(c.R*255), math.floor(c.G*255), math.floor(c.B*255))
