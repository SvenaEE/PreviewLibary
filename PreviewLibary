            UserInputService.InputEnded:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 then
                    svDragging = false; hueDragging = false; alphaDragging = false
                end
            end)
            UserInputService.InputChanged:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseMovement then
                    if svDragging then
                        local dx = math.clamp((i.Position.X - svBg.AbsolutePosition.X) / svBg.AbsoluteSize.X, 0, 1)
                        local dy = math.clamp((i.Position.Y - svBg.AbsolutePosition.Y) / svBg.AbsoluteSize.Y, 0, 1)
                        s = 1 - dx; v = 1 - dy; refreshColor()
                    elseif hueDragging then
                        h = math.clamp((i.Position.X - hueBar.AbsolutePosition.X) / hueBar.AbsoluteSize.X, 0, 1)
                        refreshColor()
                    elseif alphaDragging then
                        a = math.clamp((i.Position.X - alphaBar.AbsolutePosition.X) / alphaBar.AbsoluteSize.X, 0, 1)
                        refreshColor()
                    end
                end
            end)
        else
            if picker then picker:Destroy(); picker = nil end
        end
    end)

    UserInputService.InputBegan:Connect(function(i)
        if open and i.UserInputType == Enum.UserInputType.MouseButton1 then
            task.wait()
            if open and picker then
                local mPos = UserInputService:GetMouseLocation() - Vector2.new(0, 36)
                local ax, ay = picker.AbsolutePosition.X, picker.AbsolutePosition.Y
                local sx2, sy2 = picker.AbsoluteSize.X, picker.AbsoluteSize.Y
                if mPos.X < ax or mPos.X > ax + sx2 or mPos.Y < ay or mPos.Y > ay + sy2 then
                    open = false; picker:Destroy(); picker = nil
                end
            end
        end
    end)
end

local function AddButton(parent, text, callback)
    local isSoon = text == "SOON"
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, 0, 0, 22)
    btn.BackgroundColor3 = isSoon and THEME.ChildBg or THEME.FrameBg
    btn.BorderSizePixel = 0
    btn.Text = text
    btn.TextColor3 = isSoon and THEME.TextDisabled or THEME.Text
    btn.TextSize = 13
    ApplyFont(btn, "label")
    btn.AutoButtonColor = false
    btn.Parent = parent
    markNoDrag(btn)
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 3)
    local bs = Instance.new("UIStroke", btn); bs.Color = THEME.Border; bs.Thickness = 1
    if not isSoon then
        btn.MouseEnter:Connect(function() TweenService:Create(btn, TweenInfo.new(0.12), {BackgroundColor3 = THEME.PopupBg}):Play() end)
        btn.MouseLeave:Connect(function() TweenService:Create(btn, TweenInfo.new(0.12), {BackgroundColor3 = THEME.FrameBg}):Play() end)
        btn.MouseButton1Click:Connect(callback)
    end
end

