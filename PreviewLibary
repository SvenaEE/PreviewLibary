        cf.Visible = false
        cf.Parent = contentArea

        local lc = Instance.new("Frame"); lc.Name = "LeftCol"; lc.Size = UDim2.new(0.5, -8, 1, 0); lc.BackgroundTransparency = 1; lc.Parent = cf
        local ll2 = Instance.new("UIListLayout", lc); ll2.SortOrder = Enum.SortOrder.LayoutOrder; ll2.Padding = UDim.new(0, 12)
        local rc = Instance.new("Frame"); rc.Name = "RightCol"; rc.Size = UDim2.new(0.5, -8, 1, 0); rc.Position = UDim2.new(0.5, 8, 0, 0); rc.BackgroundTransparency = 1; rc.Parent = cf
        local rl2 = Instance.new("UIListLayout", rc); rl2.SortOrder = Enum.SortOrder.LayoutOrder; rl2.Padding = UDim.new(0, 12)

        local function select()
            if activeSubtab then
                activeSubtab.Button.TextColor3 = THEME.TextDisabled
                activeSubtab.Line.Visible = false
                if activeSubtab.Content.Visible then
                    local pc = activeSubtab.Content
                    TweenService:Create(pc, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {GroupTransparency = 1}):Play()
                    task.delay(0.2, function()
                        if pc and pc.Parent and (not activeSubtab or activeSubtab.Content ~= pc) then
                            pc.Visible = false
                        end
                    end)
                end
            end
            sbtn.TextColor3 = THEME.Scheme
            line.Visible = true
            cf.Visible = true
            cf.GroupTransparency = 1
            TweenService:Create(cf, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {GroupTransparency = 0}):Play()
            activeSubtab = { Button = sbtn, Line = line, Content = cf }
        end

        sbtn.MouseButton1Click:Connect(select)
        subtabs[name] = { Left = lc, Right = rc, Select = select }
        if index == 1 then select() end
    end

    return subtabs
end

